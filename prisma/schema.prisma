// Makada Properties — internal operating schema
// Phase 1: schema only. No heavy business logic yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum OccupancyStatus {
  OCCUPIED
  VACANT
  TURNOVER
}

enum LeaseStatus {
  ACTIVE
  UPCOMING
  ENDED
  TERMINATED
}

enum PaymentState {
  PAID
  BEHIND
  UNKNOWN
}

enum PaymentMethod {
  ONLINE    // Stripe
  CHECK
  CASH
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DocumentType {
  LEASE
  NOTICE
  RECEIPT
  INVOICE
  TAX
  INSURANCE
  RULES
  OTHER
}

enum ExpenseCategory {
  REPAIRS
  MAINTENANCE
  MANAGEMENT_FEE
  PROPERTY_TAX
  INSURANCE
  UTILITIES
  LANDSCAPING
  CLEANING
  PEST_CONTROL
  LEGAL
  SUPPLIES
  OTHER
}

enum LinkedEntityType {
  PROPERTY
  UNIT
  TENANT
  LEASE
}

enum InquirySource {
  WEBSITE
  WALK_IN
  REFERRAL
  OTHER
}

enum InquiryStatus {
  NEW
  CONTACTED
  TOURED
  REJECTED
  CONVERTED
}

// ---------- Core records ----------

model Property {
  id        String   @id @default(cuid())
  name      String
  address   String
  imageUrl  String?  // Supabase Storage signed URL or external URL
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  units    Unit[]
  expenses Expense[]
}

model Unit {
  id               String          @id @default(cuid())
  propertyId       String
  label            String
  bedrooms         Int             @default(0)
  bathrooms        Float           @default(0)
  rentAmount       Decimal         @default(0) @db.Decimal(10, 2)
  depositAmount    Decimal         @default(0) @db.Decimal(10, 2)
  occupancyStatus  OccupancyStatus @default(VACANT)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  isPublished       Boolean @default(false)
  publicDescription String?
  zillowUrl         String?  // Zillow rental listing URL for applications
  listingPhotos     String?  // JSON array of Supabase storage paths for listing photos

  property     Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  tickets      MaintenanceTicket[]
  inquiries    Inquiry[]
  expenses     Expense[]

  @@index([propertyId])
}

model Tenant {
  id                    String   @id @default(cuid())
  fullName              String
  phone                 String?
  email                 String?
  notes                 String?
  turbotenantReference  String?  // link or external ID — payments live in TurboTenant

  // Tenant-portal auth, managed entirely from the Makada admin app
  portalPassword        String?  // plaintext, admin-set; internal family-only tool
  authUserId            String?  // cached Supabase auth user id
  authLocked            Boolean  @default(false)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  leases  Lease[]
  tickets MaintenanceTicket[]
}

model Lease {
  id           String      @id @default(cuid())
  unitId       String
  tenantId     String
  startDate    DateTime
  endDate      DateTime
  monthlyRent  Decimal     @db.Decimal(10, 2)
  leaseType    String      @default("YEAR_TO_YEAR") // YEAR_TO_YEAR or MONTH_TO_MONTH
  status       LeaseStatus @default(ACTIVE)
  notes        String?

  // Lease signing workflow
  signingStatus       String?   // DRAFT | PENDING_SIGNATURE | SIGNED
  leaseDocStoragePath  String?  // Supabase path to the generated docx
  signedDocStoragePath String?  // Supabase path to the signed PDF
  sentForSigningAt     DateTime?
  signedAt             DateTime?

  // Security deposit tracking
  depositAmount          Decimal?       @db.Decimal(10, 2) // overrides unit default if set
  depositStatus          String         @default("PENDING") // PENDING, PAID, PARTIAL, REFUNDED
  depositPaidAmount      Decimal?       @db.Decimal(10, 2)
  depositPaidAt          DateTime?
  depositPaymentMethod   String?        // ONLINE, CHECK, CASH, OTHER
  depositStripeSessionId String?
  depositNote            String?

  // Late fee settings (defaults: $10/day, due on 1st, no grace period)
  lateFeePerDay    Decimal  @default(10) @db.Decimal(10, 2)
  rentDueDay       Int      @default(1)  // day of month rent is due
  gracePeriodDays  Int      @default(0)  // 0 = no grace period

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  unit            Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentStatuses PaymentStatus[]
  fees            Fee[]

  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

model PaymentStatus {
  id              String        @id @default(cuid())
  leaseId         String
  period          String        // e.g. "2026-04"
  status          PaymentState  @default(UNKNOWN)
  method          PaymentMethod?
  amountPaid      Decimal?      @db.Decimal(10, 2)
  stripeSessionId String?       // Stripe checkout session ID
  paidAt          DateTime?
  note            String?

  // Late fee tracking for this period
  lateFeeAccrued  Decimal       @default(0) @db.Decimal(10, 2)  // total late fee for this period
  lateFeePaid     Decimal       @default(0) @db.Decimal(10, 2)  // how much of the late fee has been paid
  lateFeeWaived   Boolean       @default(false)                  // admin can waive late fees

  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, period])
  @@index([leaseId])
}

// Custom fees attached to a lease (pet fee, parking, cleaning, etc.)
model Fee {
  id            String    @id @default(cuid())
  leaseId       String
  name          String    // "Pet Fee", "Parking", "Cleaning Fee", etc.
  amount        Decimal   @db.Decimal(10, 2)
  isRecurring   Boolean   @default(false)  // true = charges monthly, false = one-time
  dueDate       DateTime? // for one-time fees: when it's due
  paidStatus    String    @default("UNPAID") // UNPAID, PAID, PARTIAL, WAIVED
  paidAmount    Decimal?  @db.Decimal(10, 2)
  paidAt        DateTime?
  paymentMethod String?   // ONLINE, CHECK, CASH, OTHER
  stripeSessionId String?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([paidStatus])
}

model MaintenanceTicket {
  id          String         @id @default(cuid())
  unitId      String
  tenantId    String?
  title       String
  description String?
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  unit   Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([unitId])
  @@index([status])
}

model Document {
  id                String           @id @default(cuid())
  filename          String
  fileUrl           String           // optional cached URL; we sign at view time
  storagePath       String           // object path inside the Supabase bucket
  type              DocumentType     @default(OTHER)
  linkedEntityType  LinkedEntityType
  linkedEntityId    String
  uploadedAt        DateTime         @default(now())

  @@index([linkedEntityType, linkedEntityId])
}

model Inquiry {
  id            String         @id @default(cuid())
  unitId        String?
  prospectName  String
  phone         String?
  email         String?
  message       String?
  source        InquirySource  @default(WEBSITE)
  status        InquiryStatus  @default(NEW)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  unit Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([unitId])
  @@index([status])
}

// ---------- Expenses ----------

model Expense {
  id            String          @id @default(cuid())
  propertyId    String
  unitId        String?         // optional — some expenses are property-wide
  category      ExpenseCategory @default(OTHER)
  vendor        String?         // payee name
  description   String
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime        // when the expense occurred
  reference     String?         // check number, invoice number, etc.
  documentId    String?         // link to uploaded document
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([unitId])
  @@index([date])
}
