# Postgres connection (Supabase gives you this)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
# Server-only. Used for document uploads / deletes / signed URLs.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# Family/admin allowlist (comma-separated emails). Only these can sign in.
ALLOWED_EMAILS="attysfnm@gmail.com"

# Canonical app URL. Set in Vercel so magic-link emails point here, not localhost.
# Omit locally — the code falls back to window.location.origin for dev.
NEXT_PUBLIC_APP_URL="https://makada-app-5iv3.vercel.app"

# Tenant portal URL (Replit site). Used for magic-link invite redirects.
TENANT_PORTAL_URL="https://zmak-zmakada.replit.app"

# Shared secret used by the public Replit site to POST inquiries to /api/inquiries.
# Keep this identical on both apps. Rotate if leaked.
INQUIRY_INTAKE_SECRET="change-me-to-a-long-random-string"
